def is_triangle_div(a,l,r):
    if r-l < 2:
        return 0
    
    if r-l == 2:
        if a[l] +a[l+1]>a[l+2]:
            return 1
        return 0
    
    mid=(l+r) 
    
    return (is_triangle_div(a, l, mid + 1) or 
            is_triangle_div(a, mid, r) or 
            (a[mid-1]+a[mid]>a[mid+1]))
